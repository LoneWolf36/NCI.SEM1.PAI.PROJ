graph TD
    classDef default fill:#f9f9f9,stroke:#333,stroke-width:1px,color:#333;
    classDef source fill:#e2e8f0,stroke:#64748b,stroke-width:2px,color:#0f172a;
    classDef db fill:#cbd5e1,stroke:#475569,stroke-width:2px,color:#0f172a;
    classDef process fill:#f1f5f9,stroke:#94a3b8,stroke-width:2px,color:#0f172a;
    classDef model fill:#e2e8f0,stroke:#64748b,stroke-width:2px,color:#0f172a;
    classDef output fill:#f8fafc,stroke:#cbd5e1,stroke-width:2px,color:#0f172a;
    classDef highlight fill:#f1f5f9,stroke:#334155,stroke-width:2px,color:#0f172a;

    subgraph "1. Data Ingestion (CMS ESRD)"
        A1[patient_summary.zip]:::source
        A2[admit_treatment.zip]:::source
        A3[cl_hospitalization.zip]:::source
        A4[cl_hd_adqcy.zip]:::source
    end

    subgraph "2. Raw Storage"
        B1[(raw_patient_summary)]:::db
        B2[(raw_admit_treatment)]:::db
        B3[(raw_cl_hospitalization)]:::db
        B4[(raw_cl_hd_adqcy)]:::db
        
        A1 --> B1
        A2 --> B2
        A3 --> B3
        A4 --> B4
    end

    subgraph "3. Data Cleaning & Derivation"
        C1[Clean Tables]:::process
        B1 --> C1
        B2 --> C1
        B3 --> C1
        B4 --> C1

        D1[(derived_readmission_events)]:::db
        D2[(derived_patient_features)]:::db
        
        C1 --> D1
        C1 --> D2
    end

    subgraph "4. Feature Engineering"
        E1[(model_feature_mart)]:::db
        D1 --> E1
        D2 --> E1
        
        F1[Demographics]:::highlight
        F2[Treatment History]:::highlight
        F3[Hospitalization Features]:::highlight
        F4[Dialysis Adequacy]:::highlight
        F5[Diagnosis Context]:::highlight
        
        E1 --- F1
        E1 --- F2
        E1 --- F3
        E1 --- F4
        E1 --- F5
    end

    subgraph "5. Data Preparation"
        G1[Patient-Level Train/Test Split]:::process
        E1 --> G1
        
        G2[Imputation & Categorical Handling]:::process
        G1 --> G2
    end

    subgraph "6. Model Training & Optimization"
        H1[Logistic Regression]:::model
        H2[CatBoost]:::model
        H3[LightGBM]:::model
        
        G2 --> H1
        G2 --> H2
        G2 --> H3
        
        I1[Threshold Optimization for F1]:::process
        H1 --> I1
        H2 --> I1
        H3 --> I1
    end

    subgraph "7. Outputs & Evaluation"
        J1[Metrics JSON]:::output
        J2[(SQLite metrics tables)]:::db
        J3[SHAP & Feature Importance]:::output
        J4[Subgroup Metrics]:::output
        J5[Model Comparison Figure]:::output
        
        I1 --> J1
        I1 --> J2
        I1 --> J3
        I1 --> J4
        I1 --> J5
    end
